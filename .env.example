# Matrix 7TV Bot - Environment Configuration

# Your Matrix homeserver URL
MATRIX_HOMESERVER_URL=https://matrix.example.com

# Access token for the bot account
# You can get this by logging in as the bot and extracting the token
# Or create one via the Synapse admin API
MATRIX_ACCESS_TOKEN=syt_your_access_token_here

# The full Matrix user ID of the bot
MATRIX_BOT_USER_ID=@7tv-bot:example.com

# (Optional) Path to store bot data (sync state, etc.)
DATA_PATH=./data

# (Optional) Selection timeout in seconds
SELECTION_TIMEOUT_SEC=60
